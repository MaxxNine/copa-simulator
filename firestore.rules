rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper: Verifica se o usuário está autenticado
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper: Obtém dados do usuário logado
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    // Helper: Verifica se o usuário logado é um administrador
    function isAdmin() {
      return isAuth() && (
        // Caso o banco esteja vazio (primeiro cadastro), permite a ação administrativa de criação
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        getUserData(request.auth.uid).role == 'admin'
      );
    }

    // --- REGRAS PARA USUÁRIOS ---
    match /users/{userId} {
      allow read: if isAuth();
      
      // Qualquer usuário autenticado pode criar seu próprio perfil inicial
      allow create: if isAuth() && request.auth.uid == userId;
      
      // Atualização de perfil:
      // - Administradores podem atualizar qualquer usuário (necessário para recalcular pontos)
      // - O próprio usuário pode atualizar suas informações comuns (como displayName),
      //   mas é terminantemente PROIBIDO alterar 'role' ou 'totalPoints'
      allow update: if isAuth() && (
        isAdmin() || (
          request.auth.uid == userId &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'totalPoints']))
        )
      );
      
      allow delete: if isAdmin();
    }

    // --- REGRAS PARA PARTIDAS ---
    match /matches/all_matches {
      allow read: if isAuth();
      // Apenas administradores podem criar ou alterar o documento único de partidas
      allow write: if isAdmin();
    }

    // --- REGRAS PARA PALPITES (PREDICTIONS) ---
    match /predictions/{predId} {
      function matchIsScheduled(matchId) {
        return exists(/databases/$(database)/documents/matches/all_matches) &&
          matchId in get(/databases/$(database)/documents/matches/all_matches).data.statuses &&
          get(/databases/$(database)/documents/matches/all_matches).data.statuses[matchId] == "scheduled";
      }

      function predictionIdIsValid(userId, matchId) {
        return predId == userId + "_" + matchId;
      }

      function scoresAreValid() {
        return request.resource.data.homeScore is int &&
          request.resource.data.awayScore is int &&
          request.resource.data.homeScore >= 0 &&
          request.resource.data.awayScore >= 0;
      }

      function existingPredictionIsUnlocked() {
        return !("locked" in resource.data) || resource.data.locked != true;
      }

      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        !matchIsScheduled(resource.data.matchId) ||
        (
          "locked" in resource.data &&
          resource.data.locked == true &&
          exists(/databases/$(database)/documents/predictions/$(request.auth.uid + "_" + resource.data.matchId)) &&
          get(/databases/$(database)/documents/predictions/$(request.auth.uid + "_" + resource.data.matchId)).data.locked == true
        )
      );

      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid &&
        predictionIdIsValid(request.resource.data.userId, request.resource.data.matchId) &&
        request.resource.data.id == predId &&
        request.resource.data.keys().hasOnly(["id", "userId", "matchId", "homeScore", "awayScore", "locked"]) &&
        scoresAreValid() &&
        matchIsScheduled(request.resource.data.matchId);

      allow update: if isAuth() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.matchId == resource.data.matchId &&
        request.resource.data.id == resource.data.id &&
        predictionIdIsValid(request.resource.data.userId, request.resource.data.matchId) &&
        request.resource.data.keys().hasOnly(["id", "userId", "matchId", "homeScore", "awayScore", "locked"]) &&
        scoresAreValid() &&
        matchIsScheduled(request.resource.data.matchId) &&
        existingPredictionIsUnlocked();

      allow delete: if isAuth() &&
        resource.data.userId == request.auth.uid &&
        matchIsScheduled(resource.data.matchId) &&
        existingPredictionIsUnlocked();
    }

    // --- REGRAS PARA GRUPOS ---
    match /groups/{groupId} {
      allow read: if isAuth();
      
      // Criação de grupo: o criadorId deve ser o usuário logado
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;
      
      // Edição de grupo:
      // - O criador pode alterar o grupo
      // - Qualquer usuário pode atualizar APENAS a lista de membros para adicionar a si mesmo (ingresso por código)
      allow update: if isAuth() && (
        resource.data.creatorId == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.members
        )
      );
      
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid;
    }
  }
}
